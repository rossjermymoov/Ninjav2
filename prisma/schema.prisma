// MoveNinja V2 — Prisma Schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Sales Channels ──────────────────────────────────────────────────────────
// Stores each marketplace/channel MoveNinja receives orders from.
// slugs match the IDs returned by the Neuro API /channels/available endpoint.
// Logos are PNG URLs from the Neuro CDN; colour is a hex fallback for when
// the URL is unavailable. When Elasticsearch is added, slug + displayName are
// the primary search fields.

model Channel {
  id          String   @id @default(cuid())
  slug        String   @unique  // matches Neuro API channel id, e.g. "amazonsp"
  displayName String             // e.g. "Amazon"
  colour      String   @default("#6B7280")  // fallback badge colour (hex)
  logoUrl     String?            // PNG URL from Neuro CDN
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

// ─── Carriers ────────────────────────────────────────────────────────────────
// Stores each courier/carrier MoveNinja dispatches with.
// keys match the key field returned by the Voila API /couriers/v1/list-couriers endpoint.
// Logos are JPG URLs from the Voila CDN.

model Carrier {
  id          String   @id @default(cuid())
  key         String   @unique  // matches Voila API courier key, e.g. "Evri"
  displayName String             // e.g. "Evri"
  logoUrl     String?            // JPG URL from Voila CDN
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([isActive])
}
